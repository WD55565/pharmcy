# Copy this file to .env and fill in real values before running
# `docker compose up`. Never commit the real .env file.

# --- Database ---
DB_NAME=nobetci_eczane_plus
DB_USERNAME=app
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too

# --- Backend ---
# Comma-separated list of exact origins allowed to call the API, e.g.
# https://app.nobetcieczaneplus.com,https://admin.nobetcieczaneplus.com
CORS_ALLOWED_ORIGINS=http://localhost:8080
